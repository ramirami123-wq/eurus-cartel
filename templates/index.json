    "custom_liquid_kQnttk": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>The Beauty Cartel — Reviews</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --ivory:#F4EEE3;\n    --sand:#EADDC8;\n    --card:#FFFDF9;\n    --ink:#33291D;\n    --muted:#8A7864;\n    --terracotta:#B9764F;\n    --terracotta-deep:#9B5F3C;\n    --gold:#C08A3E;\n    --line:#E4D2B8;\n    --radius:14px;\n  }\n\n  *{box-sizing:border-box;}\n\n  body{\n    margin:0;\n    background:var(--ivory);\n    font-family:'Inter', sans-serif;\n    color:var(--ink);\n    -webkit-font-smoothing:antialiased;\n  }\n\n  .reviews-section{\n    padding:clamp(48px,8vw,96px) 0;\n    overflow:hidden;\n    position:relative;\n  }\n\n  .reviews-header{\n    max-width:640px;\n    margin:0 auto clamp(32px,6vw,56px);\n    padding:0 24px;\n    text-align:center;\n  }\n\n  .reviews-eyebrow{\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n    font-size:0.72rem;\n    letter-spacing:0.14em;\n    text-transform:uppercase;\n    color:var(--terracotta-deep);\n    font-weight:600;\n    margin-bottom:14px;\n  }\n\n  .reviews-eyebrow::before,\n  .reviews-eyebrow::after{\n    content:\"\";\n    width:20px;\n    height:1px;\n    background:var(--terracotta);\n    opacity:0.6;\n  }\n\n  .reviews-title{\n    font-family:'Fraunces', serif;\n    font-weight:500;\n    font-size:clamp(1.8rem,4vw,2.6rem);\n    line-height:1.15;\n    margin:0 0 12px;\n    letter-spacing:-0.01em;\n  }\n\n  .reviews-sub{\n    font-size:0.98rem;\n    color:var(--muted);\n    line-height:1.6;\n    margin:0;\n  }\n\n  /* ===== Marquee lanes ===== */\n  .lane-wrap{\n    position:relative;\n    -webkit-mask-image:linear-gradient(to right, transparent 0, black 64px, black calc(100% - 64px), transparent 100%);\n    mask-image:linear-gradient(to right, transparent 0, black 64px, black calc(100% - 64px), transparent 100%);\n  }\n\n  .lane{\n    display:flex;\n    width:max-content;\n    gap:20px;\n    padding:10px 0;\n  }\n\n  .lane + .lane{ margin-top:20px; }\n\n  .lane-track{\n    display:flex;\n    gap:20px;\n    animation: scroll-left 62s linear infinite;\n  }\n\n  .lane.reverse .lane-track{\n    animation-name: scroll-right;\n    animation-duration: 70s;\n  }\n\n  .lane-wrap:hover .lane-track,\n  .lane-track:focus-within{\n    animation-play-state: paused;\n  }\n\n  @keyframes scroll-left{\n    from{ transform:translateX(0); }\n    to{ transform:translateX(-50%); }\n  }\n  @keyframes scroll-right{\n    from{ transform:translateX(-50%); }\n    to{ transform:translateX(0); }\n  }\n\n  /* ===== Card ===== */\n  .review-card{\n    flex:0 0 auto;\n    width:clamp(240px,26vw,300px);\n    background:var(--card);\n    border:1px solid var(--line);\n    border-radius:var(--radius);\n    padding:22px 22px 20px;\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    box-shadow:0 1px 2px rgba(60,45,25,0.04);\n  }\n\n  .stars{\n    display:flex;\n    gap:3px;\n    color:var(--gold);\n    font-size:0.9rem;\n    letter-spacing:2px;\n  }\n\n  .review-text{\n    font-size:0.92rem;\n    line-height:1.55;\n    color:var(--ink);\n    margin:0;\n    flex-grow:1;\n  }\n\n  .review-meta{\n    display:flex;\n    align-items:baseline;\n    justify-content:space-between;\n    gap:10px;\n    padding-top:10px;\n    border-top:1px solid var(--line);\n  }\n\n  .review-name{\n    font-family:'Fraunces', serif;\n    font-weight:600;\n    font-size:0.95rem;\n    color:var(--terracotta-deep);\n  }\n\n  .review-product{\n    font-size:0.72rem;\n    color:var(--muted);\n    text-align:right;\n    line-height:1.3;\n  }\n\n  /* ===== Responsive ===== */\n  @media (max-width: 720px){\n    .lane-wrap{\n      -webkit-mask-image:linear-gradient(to right, transparent 0, black 36px, black calc(100% - 36px), transparent 100%);\n      mask-image:linear-gradient(to right, transparent 0, black 36px, black calc(100% - 36px), transparent 100%);\n    }\n    .review-card{ width:78vw; padding:18px 18px 16px; }\n    .lane-track{ animation-duration: 40s; }\n    .lane.reverse .lane-track{ animation-duration: 46s; }\n  }\n\n  @media (max-width: 420px){\n    .review-card{ width:84vw; }\n  }\n\n  @media (prefers-reduced-motion: reduce){\n    .lane-track{ animation:none; }\n    .lane-wrap{ overflow-x:auto; }\n  }\n</style>\n</head>\n<body>\n\n<section class=\"reviews-section\">\n  <div class=\"reviews-header\">\n    <span class=\"reviews-eyebrow\">Verified customers</span>\n    <h2 class=\"reviews-title\">What Customers are saying</h2>\n    <p class=\"reviews-sub\">Real words from women across Lebanon, on the pieces they didn't expect to reach for every day.</p>\n  </div>\n\n  <div class=\"lane-wrap\">\n    <!-- Lane 1 : scrolls left -->\n    <div class=\"lane\">\n      <div class=\"lane-track\" id=\"track1\"></div>\n    </div>\n    <!-- Lane 2 : scrolls right -->\n    <div class=\"lane reverse\">\n      <div class=\"lane-track\" id=\"track2\"></div>\n    </div>\n  </div>\n</section>\n\n<script>\n  const reviewsRow1 = [\n    { name: \"Nour Khalil\", rating: 5, text: \"The Silk Body Oil sinks in fast and doesn't leave that greasy film I'm used to. My skin actually looks lit from within.\", product: \"Silk Body Oil\" },\n    { name: \"Elie Boutros\", rating: 5, text: \"Ordered for my wife, cash on delivery was smooth and it arrived in two days flat. She's already reordering.\", product: \"Store experience\" },\n    { name: \"Rania Fakhoury\", rating: 4, text: \"The Bio-Collagen mask is lovely on tired skin before an event. Woke up looking rested, not just moisturized.\", product: \"Bio-Collagen Overnight Mask\" },\n    { name: \"Tarek Aoun\", rating: 5, text: \"Everything on this site feels chosen, not just stocked. Small catalog but every piece earns its spot.\", product: \"Store experience\" },\n    { name: \"Joelle Sarkis\", rating: 5, text: \"The Cyperus oil genuinely slowed regrowth after a few weeks of consistent use. Wasn't expecting real results this fast.\", product: \"Cyperus Hair-Slowing Oil\" },\n    { name: \"Karim Abou Jaoude\", rating: 4, text: \"Packaging is simple and the product itself feels premium. The massage oil has a subtle scent, not overpowering at all.\", product: \"Anti-Cellulite Massage Oil\" },\n    { name: \"Maya Chidiac\", rating: 5, text: \"I've tried three body oils this year and Silk is the only one my skin actually drank up instead of sitting on top.\", product: \"Silk Body Oil\" },\n    { name: \"Georges Nassar\", rating: 5, text: \"$3 shipping within Lebanon and it actually showed up on time. Rare these days, honestly.\", product: \"Store experience\" },\n    { name: \"Dana Achkar\", rating: 4, text: \"The overnight mask left my skin noticeably smoother by morning. A little goes a long way too.\", product: \"Bio-Collagen Overnight Mask\" },\n    { name: \"Fadi Haddad\", rating: 5, text: \"Bought this as a gift for my sister and she messaged me the same night raving about the texture.\", product: \"Silk Body Oil\" },\n  ];\n\n  const reviewsRow2 = [\n    { name: \"Lea Matar\", rating: 5, text: \"The anti-cellulite oil has become part of my nightly routine. Skin feels firmer after just three weeks.\", product: \"Anti-Cellulite Massage Oil\" },\n    { name: \"Ziad Rahme\", rating: 4, text: \"Clean site, easy checkout, and the product matched exactly what was described. No surprises, which I appreciate.\", product: \"Store experience\" },\n    { name: \"Christelle Saad\", rating: 5, text: \"I'm picky about skincare and this is the first mask that didn't irritate my sensitive skin at all.\", product: \"Bio-Collagen Overnight Mask\" },\n    { name: \"Rami Zoghbi\", rating: 5, text: \"The hair-slowing oil actually smells nice too, unlike most products in this category. Will be reordering.\", product: \"Cyperus Hair-Slowing Oil\" },\n    { name: \"Yasmine Daher\", rating: 4, text: \"Love that they don't try to sell you fifty things. Four categories, all genuinely useful.\", product: \"Store experience\" },\n    { name: \"Antoine Khoury\", rating: 5, text: \"Got the massage oil for my mother after her physio sessions. She says it's now a staple in her routine.\", product: \"Anti-Cellulite Massage Oil\" },\n    { name: \"Sarah Younes\", rating: 5, text: \"Silk Body Oil absorbs so quickly I can get dressed right after applying. No stains on clothes either.\", product: \"Silk Body Oil\" },\n    { name: \"Charbel Semaan\", rating: 4, text: \"Ordered twice now, both times delivery was quick and the packaging kept everything intact.\", product: \"Store experience\" },\n    { name: \"Nadine Ghosn\", rating: 5, text: \"The overnight mask is now a weekly ritual before any occasion. My skin looks noticeably plumper by morning.\", product: \"Bio-Collagen Overnight Mask\" },\n    { name: \"Wissam Tabet\", rating: 5, text: \"Didn't expect much from a hair oil but the regrowth really has slowed. Sticking with this one.\", product: \"Cyperus Hair-Slowing Oil\" },\n  ];\n\n  function starString(n){\n    return \"★\".repeat(n) + \"☆\".repeat(5 - n);\n  }\n\n  function buildCard(r){\n    return `\n      <article class=\"review-card\">\n        <div class=\"stars\" aria-label=\"${r.rating} out of 5 stars\">${starString(r.rating)}</div>\n        <p class=\"review-text\">${r.text}</p>\n        <div class=\"review-meta\">\n          <span class=\"review-name\">${r.name}</span>\n          <span class=\"review-product\">${r.product}</span>\n        </div>\n      </article>\n    `;\n  }\n\n  function fillTrack(id, data){\n    const track = document.getElementById(id);\n    // duplicate the set so the loop can scroll seamlessly (translate -50%)\n    const doubled = [...data, ...data];\n    track.innerHTML = doubled.map(buildCard).join(\"\");\n  }\n\n  fillTrack(\"track1\", reviewsRow1);\n  fillTrack(\"track2\", reviewsRow2);\n</script>\n\n</body>\n</html>",
